{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/a", "destination": "/a.html" },
    { "source": "/b", "destination": "/b.html" },
    { "source": "/c", "destination": "/c.html" },
    { "source": "/admin", "destination": "/admin.html" }
  ],
  "headers": [
    { "source": "/admin", "headers": [
      { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
    ]}
  ]
}
